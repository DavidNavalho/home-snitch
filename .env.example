# Filesystem roots. Relative paths resolve under the repository root.
HOME_WIKI_SOURCE_DOCS=source_docs
HOME_WIKI_MARKDOWN_DOCS=markdown_docs
HOME_WIKI_LANCEDB_DIR=lancedb_data
HOME_WIKI_TABLE=home_wiki_chunks
HOME_WIKI_DEVICE_REGISTRY=data/devices.sqlite
HOME_WIKI_INGEST_MANIFEST=data/ingest_manifest.sqlite

# Embeddings. Use fake for deterministic offline tests only.
EMBEDDING_PROVIDER=fake
EMBEDDING_API_BASE=http://localhost:1234/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
GGUF_MODEL_REPO=
GGUF_MODEL_FILE=
GGUF_N_CTX=8192
GGUF_N_THREADS=4

# Chat generation. Disabled keeps ask flows evidence-only by default.
CHAT_PROVIDER=disabled
CHAT_API_BASE=
CHAT_API_KEY=
CHAT_MODEL=

# Local API/UI defaults.
API_HOST=127.0.0.1
API_PORT=8000
UI_API_BASE=http://127.0.0.1:8000
